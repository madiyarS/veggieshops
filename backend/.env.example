# Server
PORT=8080

# Redis (кэш каталога; пусто — без Redis)
REDIS_ADDR=

# Фоновые задачи (устаревшие pending-заказы)
PENDING_ORDER_TIMEOUT_MIN=120
STALE_ORDER_SWEEP_INTERVAL_SEC=300

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=password
DB_NAME=veggies_shop
DB_SSLMODE=disable

# JWT
JWT_SECRET=your-secret-key-change-in-production
JWT_ACCESS_EXP=60
JWT_REFRESH_EXP=168

# External API Keys (для интеграций)
KASPI_API_KEY=your-kaspi-key
HALYK_API_KEY=your-halyk-key
WHATSAPP_API_KEY=your-whatsapp-key
